# ── Telegram Bot Settings ──────────────────────────────
# Get these from @BotFather on Telegram (see README for steps)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── News Topic ─────────────────────────────────────────
# What topic do you want headlines for?
# Examples: technology, sports, climate change, AI, bitcoin
#TOPIC=artificial intelligence

# ── Dry Run ────────────────────────────────────────────
# Set to "true" to print the summary WITHOUT sending to Telegram.
# Useful for testing! You can also use:  python main.py --dry-run
DRY_RUN=false
